<Window x:Class="EdaSimulator.UI.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help &amp; Keyboard Shortcuts" Height="580" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#FF13131F" Foreground="White" FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF1A1A30" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📖" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="Help &amp; Keyboard Reference" FontSize="20" FontWeight="Bold" Foreground="#FF5BB4FF"/>
                    <TextBlock Text="EDA Simulator Platform — Quick Reference Guide" FontSize="11" Foreground="#FF888AAA"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Background="#FF1B1B2F" BorderBrush="#FF3A3A5C"
                    TabStripPlacement="Left">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#FF1E1E38"/>
                    <Setter Property="Foreground" Value="#FFAAAACC"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="14,8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FF2A2A50"/>
                            <Setter Property="Foreground" Value="#FF5BB4FF"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- Keyboard Shortcuts -->
            <TabItem Header="⌨  Shortcuts">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Keyboard Shortcuts" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF5BB4FF" Margin="0,0,0,14"/>

                        <TextBlock Text="FILE" Foreground="#FF666888" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Ctrl+N" Action="New Project"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Ctrl+O" Action="Open Project"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Ctrl+S" Action="Save Project"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Ctrl+Shift+S" Action="Save As..."/>

                        <TextBlock Text="CANVAS" Foreground="#FF666888" FontSize="11" FontWeight="Bold" Margin="0,14,0,6"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="W" Action="Activate Wiring Tool"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Escape" Action="Cancel / Switch to Selection"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Delete" Action="Delete Selected Component"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Ctrl+Z" Action="Undo"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Ctrl+Y" Action="Redo"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Ctrl+A" Action="Select All"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Middle Mouse" Action="Pan Canvas"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Scroll Wheel" Action="Zoom In / Out"/>

                        <TextBlock Text="SIMULATION" Foreground="#FF666888" FontSize="11" FontWeight="Bold" Margin="0,14,0,6"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="F5" Action="Run Simulation"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="F6" Action="Generate SPICE Netlist"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Shift+F5" Action="Stop Simulation"/>

                        <TextBlock Text="VIEW" Foreground="#FF666888" FontSize="11" FontWeight="Bold" Margin="0,14,0,6"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Ctrl+," Action="Open Preferences"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="F1" Action="Help"/>
                        <local:ShortcutRow xmlns:local="clr-namespace:EdaSimulator.UI.Views" Key="Ctrl+Shift+H" Action="Component Hub"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Getting Started -->
            <TabItem Header="🚀  Getting Started">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Getting Started" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF5BB4FF" Margin="0,0,0,14"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#FFCCCCCC" LineHeight="22" FontSize="13">
                            <Run FontWeight="Bold" Foreground="#FF9DCBF5">1. Place Components</Run>
                            <LineBreak/>
                            <Run>Use the left-hand Parts Bin to select and place components onto the canvas. Click a category to expand it, then click a part to switch to Placement Mode. Click on the canvas to place it.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="#FF9DCBF5">2. Draw Wires</Run>
                            <LineBreak/>
                            <Run>Press W to activate the Wiring Tool. Click on a component pin (the small green square) to start a wire, then click another pin to complete the connection. Press Escape to cancel.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="#FF9DCBF5">3. Configure Simulation</Run>
                            <LineBreak/>
                            <Run>Use the right-hand panel to select your simulation type (Transient, AC Sweep, or DC Sweep) and configure its parameters.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="#FF9DCBF5">4. Run the Simulation</Run>
                            <LineBreak/>
                            <Run>Click Simulate (F5). The DRC will verify your circuit first. If valid, ngspice executes in the background and the Oscilloscope opens with your waveform results.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="#FF9DCBF5">5. Analyse Waveforms</Run>
                            <LineBreak/>
                            <Run>Use the Oscilloscope viewer to zoom, pan, and inspect signals. Add Voltage Probe components to the canvas to trace specific nodes.</Run>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Simulation Guide -->
            <TabItem Header="⚡  Simulation">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Simulation Analysis Types" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF5BB4FF" Margin="0,0,0,14"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#FFCCCCCC" LineHeight="22" FontSize="13">
                            <Run FontWeight="Bold" Foreground="#FFFFAA44">.tran — Transient Analysis</Run>
                            <LineBreak/>
                            <Run>Simulates circuit behaviour over time. Best for viewing signals, oscillations, and pulse responses. Parameters: Stop Time, Step Time.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="#FFFFAA44">.ac — AC Sweep (Frequency Response)</Run>
                            <LineBreak/>
                            <Run>Sweeps the input frequency logarithmically and computes gain/phase at each point. Generates Bode plots. Parameters: Start Hz, Stop Hz, Points/Decade.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="#FFFFAA44">.dc — DC Sweep</Run>
                            <LineBreak/>
                            <Run>Sweeps a DC source from a start to stop voltage and records the operating point at each step. Useful for I-V curves of diodes and transistors.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="#FFFFAA44">S-Parameter / RF Analysis</Run>
                            <LineBreak/>
                            <Run>Import IEEE Touchstone (.s2p, .sNp) files via Tools → Component Hub. The physics engine performs linear interpolation across the loaded frequency data for AC Sweep co-simulation.</Run>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- FreeRouting Setup -->
            <TabItem Header="🛠  FreeRouting">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Text="FreeRouting Auto-Router Setup" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF5BB4FF" Margin="0,0,0,14"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#FFCCCCCC" LineHeight="22" FontSize="13">
                            <Run>The platform includes a built-in Specctra DSN exporter and SES importer to integrate with FreeRouting, an industry-standard open-source auto-router.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="#FF9DCBF5">1. Download FreeRouting</Run>
                            <LineBreak/>
                            <Run>Download the executable jar or app from the official repository (https://github.com/freerouting/freerouting).</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="#FF9DCBF5">2. Configure Path in Preferences</Run>
                            <LineBreak/>
                            <Run>Open Preferences (Ctrl+,), locate the "FreeRouting Path" setting under the PCB section, and click "Browse" to select your downloaded FreeRouting executable/JAR.</Run>
                            <LineBreak/><LineBreak/>
                            <Run FontWeight="Bold" Foreground="#FF9DCBF5">3. Run the Auto-Router</Run>
                            <LineBreak/>
                            <Run>Once configured, click "Auto-Route" in the PCB Layout toolbar. The platform will automatically export the Specctra DSN netlist, launch FreeRouting in the background to calculate the trace topology, and import the resulting Specctra SES file back onto your PCB canvas.</Run>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- About -->
            <TabItem Header="ℹ  About">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                    <TextBlock Text="EDA Simulator Platform" FontSize="26" FontWeight="Bold"
                               Foreground="#FF5BB4FF" HorizontalAlignment="Center"/>
                    <TextBlock Text="Version 0.9.0 — Phase 8 (Release Candidate)" FontSize="13"
                               Foreground="#FF888AAA" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <Separator Margin="0,18" Background="#FF3A3A5C"/>
                    <TextBlock TextWrapping="Wrap" MaxWidth="500" HorizontalAlignment="Center"
                               TextAlignment="Center" Foreground="#FFCCCCCC" FontSize="13" LineHeight="22">
                        A professional-grade EDA and circuit simulation platform
targeting the capabilities of Proteus Professional, MATLAB/Simulink,
and ANSYS — built on .NET 8, WPF, and industry-standard ngspice.
                    </TextBlock>
                    <Separator Margin="0,18" Background="#FF3A3A5C"/>
                    <TextBlock Text="Technology Stack" FontSize="13" FontWeight="Bold"
                               Foreground="#FF9DCBF5" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text=".NET 8  ·  WPF  ·  ngspice  ·  OxyPlot  ·  MathNet.Numerics  ·  CommunityToolkit.Mvvm"
                               Foreground="#FF888AAA" HorizontalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
