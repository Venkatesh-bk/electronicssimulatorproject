<Window x:Class="EdaSimulator.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EdaSimulator.UI.Views"
        xmlns:canvasVm="clr-namespace:EdaSimulator.UI.ViewModels.Canvas"
        xmlns:helix="http://helix-toolkit.org/wpf"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="800" Width="1280"
        Background="#FF1E1E1E" Foreground="White"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- ============================================================ -->
        <!-- MENU BAR                                                     -->
        <!-- ============================================================ -->
        <Menu DockPanel.Dock="Top" Background="#FF252526" Foreground="White" FontSize="13">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Background" Value="#FF252526"/>
                    <Setter Property="Foreground" Value="#FFCCCCCC"/>
                </Style>
            </Menu.Resources>

            <MenuItem Header="_File">
                <MenuItem Header="_New Project" Command="{Binding NewProjectCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open Project..." Command="{Binding LoadProjectCommand}" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save Project" Command="{Binding SaveProjectCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save Project _As..." Command="{Binding SaveProjectAsCommand}"/>
                <Separator/>
                <MenuItem Header="Export SPICE _Netlist (.cir)..." Command="{Binding ExportNetlistToFileCommand}"/>
                <MenuItem Header="Export Schematic as _PNG..." Click="MenuExportPng_Click" InputGestureText="Ctrl+Shift+E"/>
                <MenuItem Header="Export Schematic as _SVG..." Click="MenuExportSvg_Click" InputGestureText="Ctrl+Shift+V"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="MenuExit_Click"/>
            </MenuItem>

            <MenuItem Header="_Simulation">
                <MenuItem Header="Run Simulation ▶" Command="{Binding SimulateCommand}"/>
                <MenuItem Header="Stop Simulation ■" Command="{Binding StopSimulationCommand}"/>
                <Separator/>
                <MenuItem Header="Generate Netlist (.cir)" Command="{Binding GenerateNetlistWithModeCommand}"/>
                <Separator/>
                <MenuItem Header="📰 Sync to PCB Layout" Command="{Binding SyncPcbCommand}" InputGestureText="Ctrl+Shift+P"/>
                <Separator/>
                <MenuItem Header="Build Complex Circuit (Sallen-Key)" Command="{Binding AddMockComponentsCommand}"/>
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Zoom In (+)" Click="MenuZoomIn_Click"/>
                <MenuItem Header="Zoom Out (-)" Click="MenuZoomOut_Click"/>
                <MenuItem Header="Reset Zoom" Click="MenuZoomReset_Click"/>
                <MenuItem Header="Zoom to Fit" Click="MenuZoomFit_Click" InputGestureText="Ctrl+Shift+F"/>
                <Separator/>
                <MenuItem Header="Show DC Bias Voltages" IsCheckable="True" IsChecked="{Binding ShowDcBiasOverlay}"/>
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="⚡  _Component Hub..." Click="MenuComponentHub_Click" InputGestureText="Ctrl+Shift+H"/>
                <Separator/>
                <MenuItem Header="🔬  Run PCB DRC" Click="MenuPcbDrc_Click" InputGestureText="Ctrl+D"/>
                <Separator/>
                <MenuItem Header="⚙️  _Preferences..." Click="MenuSettings_Click" InputGestureText="Ctrl+,"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="📖  _Help &amp; Shortcuts" Click="MenuHelp_Click" InputGestureText="F1"/>
                <Separator/>
                <MenuItem Header="License Activation..." Click="MenuActivation_Click"/>
                <MenuItem Header="Open Knowledge Base..." Click="MenuKnowledgeBase_Click"/>
                <Separator/>
                <MenuItem Header="About EDA Simulator" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- ============================================================ -->
        <!-- STATUS BAR                                                   -->
        <!-- ============================================================ -->
        <StatusBar DockPanel.Dock="Bottom" Background="#FF007ACC" Foreground="White" Height="24">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ToolTip="Live Design Rule Check (DRC) Status">
                    <Ellipse Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF2ECC71"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDrcValid}" Value="False">
                                        <Setter Property="Fill" Value="#FFE74C3C"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding DrcStatusMessage}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FF2ECC71"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDrcValid}" Value="False">
                                        <Setter Property="Foreground" Value="#FFE74C3C"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock FontSize="11">
                    <Run Text="X:"/>
                    <Run Text="{Binding MouseCanvasX, StringFormat='{}{0:F0}'}"/>
                    <Run Text="  Y:"/>
                    <Run Text="{Binding MouseCanvasY, StringFormat='{}{0:F0}'}"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding ActiveToolName, StringFormat='Tool: {0}'}" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main content Grid -->
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="250" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Toolbox -->
        <Border Grid.Column="0" Background="#FF252526" BorderBrush="#FF3F3F46" BorderThickness="0,0,1,0">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="Toolbox" FontWeight="Bold" FontSize="16" Foreground="#FFCCCCCC" Margin="0,0,0,5"/>
                
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Top" FlowDirection="LeftToRight">
                    <Button Content="↖ Cursor" Click="SelectTool_Click"
                            Background="#FF3F3F46" Foreground="White" BorderThickness="0"
                            Padding="6,4" Margin="0,0,3,0" ToolTip="Select tool (Esc)"/>
                    <Button Content="〰 Wire" Click="WireTool_Click"
                            Background="#FF007ACC" Foreground="White" BorderThickness="0"
                            Padding="6,4" Margin="0,0,3,0" ToolTip="Wire tool (W)"/>
                    <Button Content="⚡ Probe" Click="ProbeTool_Click"
                            Background="#FF2ECC71" Foreground="Black" BorderThickness="0"
                            Padding="6,4" Margin="0,0,3,0" ToolTip="Voltage Probe tool (P) — click a wire to capture its waveform"/>
                    <Button Content="〜 I-Probe" Click="CurrentProbeTool_Click"
                            Background="#FFE67E22" Foreground="White" BorderThickness="0"
                            Padding="6,4" Margin="0,0,3,0" ToolTip="Current Probe tool (I)"/>
                    <Button Content="🏷 Label" Click="NetLabelTool_Click"
                            Background="#FF9B59B6" Foreground="White" BorderThickness="0"
                            Padding="6,4" Margin="0,0,10,0" ToolTip="Net Label tool (L) — click a wire to assign a name"/>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,6,0"/>
                    <Button Content="↩ Undo" Click="Undo_Click"
                            Background="#FF252526" Foreground="#FFAAAAAA" BorderBrush="#FF3F3F46" BorderThickness="1"
                            Padding="6,4" Margin="0,0,3,0" ToolTip="Undo (Ctrl+Z)"/>
                    <Button Content="↪ Redo" Click="Redo_Click"
                            Background="#FF252526" Foreground="#FFAAAAAA" BorderBrush="#FF3F3F46" BorderThickness="1"
                            Padding="6,4" ToolTip="Redo (Ctrl+Y)"/>
                </StackPanel>
                
                <ListBox x:Name="ToolboxList" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="White" Margin="0,35,0,0"
                         PreviewMouseLeftButtonDown="ToolboxList_PreviewMouseLeftButtonDown"
                         MouseMove="ToolboxList_MouseMove">
                    <ListBoxItem Content="Resistor" Tag="Resistor" />
                    <ListBoxItem Content="Capacitor" Tag="Capacitor" />
                    <ListBoxItem Content="Inductor" Tag="Inductor" />
                    <ListBoxItem Content="Voltage Source" Tag="VoltageSource" />
                    <ListBoxItem Content="Current Source" Tag="CurrentSource" />
                    <ListBoxItem Content="Interactive Switch" Tag="Switch" Foreground="#FFFF9800" FontWeight="SemiBold"/>
                    <ListBoxItem Content="Potentiometer" Tag="Potentiometer" Foreground="#FFFF9800" FontWeight="SemiBold"/>
                    
                    <!-- Phase 4 Analog Components -->
                    <ListBoxItem Content="Diode" Tag="Diode" Foreground="#FF569CD6" />
                    <ListBoxItem Content="BJT (NPN)" Tag="BJT" Foreground="#FF569CD6" />
                    <ListBoxItem Content="MOSFET (NMOS)" Tag="MOSFET" Foreground="#FF569CD6" />
                    <ListBoxItem Content="Op-Amp" Tag="OpAmp" Foreground="#FF569CD6" />

                    <!-- Phase 4 Digital Gates -->
                    <ListBoxItem Content="AND Gate"  Tag="AndGate"  Foreground="#FF4EC9B0" />
                    <ListBoxItem Content="OR Gate"   Tag="OrGate"   Foreground="#FF4EC9B0" />
                    <ListBoxItem Content="NAND Gate" Tag="NandGate" Foreground="#FF4EC9B0" />
                    <ListBoxItem Content="NOR Gate"  Tag="NorGate"  Foreground="#FF4EC9B0" />
                    <ListBoxItem Content="NOT Gate"  Tag="NotGate"  Foreground="#FF4EC9B0" />
                    <ListBoxItem Content="XOR Gate"  Tag="XorGate"  Foreground="#FF4EC9B0" />
                    <ListBoxItem Content="D Flip-Flop" Tag="DFlipFlop" Foreground="#FF4EC9B0" />

                    <!-- Microcontrollers (MCU) -->
                    <ListBoxItem Content="Arduino Uno R3" Tag="ArduinoUno" Foreground="#FFC586C0" FontWeight="SemiBold"/>
                    <ListBoxItem Content="ESP32-WROOM" Tag="Esp32Wroom" Foreground="#FFC586C0" FontWeight="SemiBold"/>
                    <ListBoxItem Content="STM32 Blue Pill" Tag="Stm32BluePill" Foreground="#FFC586C0" FontWeight="SemiBold"/>

                    <!-- Sources -->
                    <ListBoxItem Content="─────────" IsEnabled="False" Foreground="#FF555555"/>
                    <ListBoxItem Content="~ SIN Source" Tag="SinVSource" Foreground="#FFFFD700" FontWeight="SemiBold"/>

                    <!-- Power Symbols -->
                    <ListBoxItem Content="─────────" IsEnabled="False" Foreground="#FF555555"/>
                    <ListBoxItem Content="⏚  Ground (GND)" Tag="Ground" Foreground="#FFFFCC00" FontWeight="SemiBold"/>
                    <ListBoxItem Content="↑  VCC  (+5V)"   Tag="VCC"    Foreground="#FFFF6060" FontWeight="SemiBold"/>
                    <ListBoxItem Content="↑  VDD  (+3.3V)" Tag="VDD"    Foreground="#FFFF6060" FontWeight="SemiBold"/>
                    <ListBoxItem Content="↑  +12V"         Tag="V12"    Foreground="#FFFF8C00" FontWeight="SemiBold"/>
                    <ListBoxItem Content="↓  -12V"         Tag="VN12"   Foreground="#FF87CEEB" FontWeight="SemiBold"/>

                    <!-- Mathematical Simulink Blocks -->
                    <ListBoxItem Content="─────────" IsEnabled="False" Foreground="#FF555555"/>
                    <ListBoxItem Content=" Gain Block" Tag="BlockGain" Foreground="#FF00D2FF" FontWeight="SemiBold"/>
                    <ListBoxItem Content="∫ Integrator Block" Tag="BlockIntegrator" Foreground="#FF00D2FF" FontWeight="SemiBold"/>
                    <ListBoxItem Content="∑ Sum Block" Tag="BlockSum" Foreground="#FF00D2FF" FontWeight="SemiBold"/>
                    <ListBoxItem Content="📶 Signal Source Block" Tag="BlockSource" Foreground="#FF00D2FF" FontWeight="SemiBold"/>
                    <ListBoxItem Content="➗ Transfer Function Block" Tag="BlockTransferFunction" Foreground="#FF00D2FF" FontWeight="SemiBold"/>
                    <ListBoxItem Content="📝 Text Note/Annotation" Tag="AnnotationNote" Foreground="#FFFFEB3B" FontWeight="SemiBold"/>
                </ListBox>
                
                <Button Grid.Row="2" Content="Build Complex Circuit" Command="{Binding AddMockComponentsCommand}" Padding="5" Margin="0,10,0,0" Background="#FF007ACC" Foreground="White" BorderThickness="0" />
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#FF3F3F46" />

        <!-- Center Panel: Canvas Workspace -->
        <Grid Grid.Column="2" Background="#FF1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="150" />
            </Grid.RowDefinitions>

            <!-- Multi-sheet Schematic Tab Bar -->
            <Border Grid.Row="0" Background="#FF1E1E24" BorderBrush="#FF2D2D30" BorderThickness="0,0,0,1" Height="32">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ListBox ItemsSource="{Binding SchematicSheets}" 
                             SelectedItem="{Binding SelectedSchematicSheet}" 
                             Background="Transparent" BorderThickness="0" 
                             ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#FFAAAAAA"/>
                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                                    Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="✕" 
                                                            Command="{Binding DataContext.RemoveSchematicSheetCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                            CommandParameter="{Binding}" 
                                                            Background="Transparent" Foreground="#FF888888" BorderThickness="0" 
                                                            Width="14" Height="14" Margin="6,0,0,0" FontSize="8" 
                                                            Cursor="Hand" ToolTip="Remove Sheet"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FF252526"/>
                                        <Setter Property="Foreground" Value="#FF007ACC"/>
                                        <Setter Property="BorderBrush" Value="#FF007ACC"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Column="1" Content="➕ Add Sheet" 
                            Command="{Binding AddSchematicSheetCommand}" 
                            Background="#FF2D2D30" Foreground="#FF007ACC" FontWeight="SemiBold" 
                            BorderThickness="1" BorderBrush="#FF3F3F46" Padding="10,0" Margin="4" 
                            Height="24" FontSize="10" Cursor="Hand"/>
                </Grid>
            </Border>
            
            <!-- Schematic Canvas Workspace -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" Background="#FF1E1E1E" Name="MainScrollViewer">
                <!-- Inner Grid bounded to actual physics bounds layer, sharing the transform context -->
                <Grid Width="10000" Height="10000" Background="Transparent"
                      MouseDown="SchematicCanvas_MouseDown"
                      MouseMove="SchematicCanvas_MouseMove"
                      MouseUp="SchematicCanvas_MouseUp"
                      MouseWheel="SchematicCanvas_MouseWheel"
                      AllowDrop="True"
                      Drop="SchematicCanvas_Drop">

                      
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="{Binding ActiveSchematicViewModel.ZoomFactor}" ScaleY="{Binding ActiveSchematicViewModel.ZoomFactor}" />
                            <TranslateTransform X="{Binding ActiveSchematicViewModel.PanX}" Y="{Binding ActiveSchematicViewModel.PanY}" />
                        </TransformGroup>
                    </Grid.RenderTransform>

                    <ItemsControl x:Name="SchematicItemsControl" 
                                  ItemsSource="{Binding ActiveSchematicViewModel.Items}"
                                  MouseDoubleClick="SchematicCanvas_MouseDoubleClick">
                        
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas ClipToBounds="True" IsItemsHost="True">
                                <Canvas.Background>
                                    <DrawingBrush TileMode="Tile" Viewport="0,0,100,100" ViewportUnits="Absolute">
                                        <DrawingBrush.Drawing>
                                            <GeometryDrawing>
                                                <GeometryDrawing.Geometry>
                                                    <!-- Faint 10x10 dot grid -->
                                                    <GeometryGroup>
                                                        <LineGeometry StartPoint="0,0" EndPoint="100,0"/>
                                                        <LineGeometry StartPoint="0,10" EndPoint="100,10"/>
                                                        <LineGeometry StartPoint="0,20" EndPoint="100,20"/>
                                                        <LineGeometry StartPoint="0,30" EndPoint="100,30"/>
                                                        <LineGeometry StartPoint="0,40" EndPoint="100,40"/>
                                                        <LineGeometry StartPoint="0,50" EndPoint="100,50"/>
                                                        <LineGeometry StartPoint="0,60" EndPoint="100,60"/>
                                                        <LineGeometry StartPoint="0,70" EndPoint="100,70"/>
                                                        <LineGeometry StartPoint="0,80" EndPoint="100,80"/>
                                                        <LineGeometry StartPoint="0,90" EndPoint="100,90"/>
                                                        <LineGeometry StartPoint="0,0" EndPoint="0,100"/>
                                                        <LineGeometry StartPoint="10,0" EndPoint="10,100"/>
                                                        <LineGeometry StartPoint="20,0" EndPoint="20,100"/>
                                                        <LineGeometry StartPoint="30,0" EndPoint="30,100"/>
                                                        <LineGeometry StartPoint="40,0" EndPoint="40,100"/>
                                                        <LineGeometry StartPoint="50,0" EndPoint="50,100"/>
                                                        <LineGeometry StartPoint="60,0" EndPoint="60,100"/>
                                                        <LineGeometry StartPoint="70,0" EndPoint="70,100"/>
                                                        <LineGeometry StartPoint="80,0" EndPoint="80,100"/>
                                                        <LineGeometry StartPoint="90,0" EndPoint="90,100"/>
                                                    </GeometryGroup>
                                                </GeometryDrawing.Geometry>
                                                <GeometryDrawing.Pen>
                                                    <Pen Brush="#FF2A2A2A" Thickness="1" />
                                                </GeometryDrawing.Pen>
                                            </GeometryDrawing>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Canvas.Background>
                            </Canvas>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.Resources>
                        <!-- Proper layered component symbol renderer -->
                        <DataTemplate DataType="{x:Type canvasVm:ComponentNodeViewModel}">
                            <Grid Width="{Binding BoundsWidth}" Height="{Binding BoundsHeight}">
                                <Grid.RenderTransform>
                                    <RotateTransform Angle="{Binding RotationAngle}" />
                                </Grid.RenderTransform>
                                <Grid.RenderTransformOrigin>
                                    <Point X="0.5" Y="0.5" />
                                </Grid.RenderTransformOrigin>

                                <!-- ① Selection Highlight border -->
                                <Rectangle x:Name="SelectionHighlight"
                                           Stroke="#FFFFFF00" StrokeThickness="1.5"
                                           StrokeDashArray="3,2" Fill="Transparent"
                                           Visibility="Hidden" RadiusX="2" RadiusY="2"/>

                                <!-- ② Symbol: fixed ViewBox so the PathData fills the bounds cleanly -->
                                <Viewbox Stretch="Uniform" Margin="4">
                                    <Canvas Width="{Binding BoundsWidth}" Height="{Binding BoundsHeight}">
                                        <Path x:Name="SymbolPath" Data="{Binding PathData}"
                                              Stroke="#FF4FC3F7" StrokeThickness="2"
                                              Fill="Transparent"
                                              Canvas.Left="{Binding BoundsWidth, Converter={x:Static canvasVm:HalfValueConverter.Instance}}"
                                              Canvas.Top="{Binding BoundsHeight, Converter={x:Static canvasVm:HalfValueConverter.Instance}}">
                                            <Path.RenderTransform>
                                                <ScaleTransform ScaleX="{Binding ScaleX}" ScaleY="{Binding ScaleY}"/>
                                            </Path.RenderTransform>
                                        </Path>
                                    </Canvas>
                                </Viewbox>

                                <!-- ③ Designator label — above the symbol -->
                                <TextBlock x:Name="DesignatorLabel" Text="{Binding Designator}"
                                           Foreground="#FFFFFFFF"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Top"
                                           Margin="0,-16,0,0"/>

                                <!-- ④ Value label — below the symbol -->
                                <TextBlock x:Name="ValueLabel" Text="{Binding Value}"
                                           Foreground="#FF90CAF9"
                                           FontFamily="Consolas" FontSize="9"
                                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                           Margin="0,0,0,-15"/>

                                <!-- ⑤ Power label — only visible for power rails -->
                                <TextBlock x:Name="PowerLabelBlock" Text="{Binding PowerLabel}"
                                           Foreground="#FFE74C3C" Visibility="Collapsed"
                                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Top"
                                           Margin="0,-16,0,0"/>
                            </Grid>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="SelectionHighlight" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsGround}" Value="True">
                                    <Setter TargetName="SymbolPath" Property="Stroke" Value="#FF95A5A6" />
                                    <Setter TargetName="DesignatorLabel" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="ValueLabel" Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsPower}" Value="True">
                                    <Setter TargetName="SymbolPath" Property="Stroke" Value="#FFE74C3C" />
                                    <Setter TargetName="DesignatorLabel" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="ValueLabel" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="PowerLabelBlock" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type canvasVm:WireViewModel}">
                            <!-- Renders a multi-point sequence of wires orthogonally -->
                            <Canvas>
                                <Polyline x:Name="WirePolyline" Points="{Binding Points}" Stroke="{Binding WireColor, FallbackValue=#FF00FF00}" StrokeThickness="2" />
                                <!-- Net name label centered at wire midpoint -->
                                <Border Canvas.Left="{Binding LabelX}" Canvas.Top="{Binding LabelY}" Margin="0,-12,0,0"
                                        Background="#AA1E1E1E" BorderBrush="#4400FF00" BorderThickness="1"
                                        CornerRadius="2" Padding="2,0"
                                        Visibility="{Binding NetLabel, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding NetLabel}" Foreground="#FF00BB00"
                                               FontFamily="Consolas" FontSize="9"/>
                                </Border>

                                <!-- Operating Point Annotation Badge -->
                                <Border Canvas.Left="{Binding LabelX}" Canvas.Top="{Binding LabelY}" Margin="0,4,0,0"
                                        Background="#CC111111" BorderBrush="#88FF8800" BorderThickness="1"
                                        CornerRadius="3" Padding="3,1"
                                        Visibility="{Binding ShowOpVoltage, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding OpVoltageText}" Foreground="#FFFF8800"
                                               FontFamily="Consolas" FontSize="9.5" FontWeight="Bold"/>
                                </Border>
                            </Canvas>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="WirePolyline" Property="Stroke" Value="#FFFFD700" />
                                    <Setter TargetName="WirePolyline" Property="StrokeThickness" Value="3.5" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type canvasVm:PinNodeViewModel}">
                            <Grid Margin="-5,-5,0,0">
                                <!-- Visual connector pin: GREEN when wired, RED when floating -->
                                <Ellipse Width="10" Height="10" StrokeThickness="1.5">
                                    <Ellipse.ToolTip>
                                        <ToolTip Background="#252526" BorderBrush="#3F3F46" BorderThickness="1">
                                            <StackPanel Orientation="Vertical" Margin="2">
                                                <TextBlock Text="{Binding Name, StringFormat='Pin: {0}'}" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Foreground="#FF00CC44">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding ConnectedNetName, StringFormat='Net: {0}'}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                                    <Setter Property="Text" Value="Net: Floating"/>
                                                                    <Setter Property="Foreground" Value="#FFFF4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </ToolTip>
                                    </Ellipse.ToolTip>
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <!-- Default: floating = red -->
                                            <Setter Property="Fill"   Value="#FFCC2222"/>
                                            <Setter Property="Stroke" Value="#FFFF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Fill"   Value="#FF00CC44"/>
                                                    <Setter Property="Stroke" Value="#FF00FF66"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsHovered}" Value="True">
                                                    <Setter Property="Fill"   Value="#FFFFE066"/>
                                                    <Setter Property="Stroke" Value="#FFFFFFFF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                
                                <!-- Engine DRC Floating Validation Visual ('Red X' overlay) -->
                                <Path x:Name="ErrorCross" Data="M -4,-4 L 4,4 M -4,4 L 4,-4" Stroke="Red" StrokeThickness="2" 
                                      Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter TargetName="ErrorCross" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>

                        <!-- Voltage Probe Visual Representation -->
                        <DataTemplate DataType="{x:Type canvasVm:VoltageProbeItemViewModel}">
                            <Grid Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}" Margin="-10,-10,0,0">
                                <!-- Simple graphical pin indicator -->
                                <Path Data="M 10,10 L 20,0 L 20,20 Z" Fill="#FF007ACC" Stroke="White" StrokeThickness="1" />
                                <TextBlock Text="V" FontWeight="Bold" Foreground="White" FontSize="10" Margin="14,4,0,0" />
                                
                                <Border Background="#CC1E1E1E" BorderBrush="#FF007ACC" BorderThickness="1" CornerRadius="3" Margin="25,-10,-20,0" Padding="2" HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding TargetNetName}" Foreground="#FF007ACC" FontSize="10" />
                                </Border>
                            </Grid>
                        </DataTemplate>

                        <!-- Current Probe Visual Representation -->
                        <DataTemplate DataType="{x:Type canvasVm:CurrentProbeItemViewModel}">
                            <Grid Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}" Margin="-10,-10,0,0">
                                <!-- Current arrow graphic -->
                                <Path Data="M 15,0 L 30,10 L 15,20 Z" Fill="#FFD700" Stroke="White" StrokeThickness="1" />
                                <TextBlock Text="A" FontWeight="Bold" Foreground="Black" FontSize="10" Margin="16,4,0,0" />
                                
                                <Border Background="#CC1E1E1E" BorderBrush="#FFD700" BorderThickness="1" CornerRadius="3" Margin="32,-10,-20,0" Padding="2" HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding TargetDeviceDesignator}" Foreground="#FFD700" FontSize="10" />
                                </Border>
                            </Grid>
                        </DataTemplate>

                        <!-- Net Label Visual Representation -->
                        <DataTemplate DataType="{x:Type canvasVm:NetLabelItemViewModel}">
                            <Grid Width="60" Height="22" Background="Transparent" Margin="-30,-11,0,0">
                                <!-- Selection Highlight border -->
                                <Rectangle x:Name="SelectionHighlight"
                                           Stroke="#FFFFFF00" StrokeThickness="1.5"
                                           StrokeDashArray="3,2" Fill="Transparent"
                                           Visibility="Hidden" RadiusX="3" RadiusY="3" Margin="-2"/>

                                <Border Background="#EE2A1E2D" BorderBrush="#FF9B59B6" BorderThickness="1.5" CornerRadius="3" Padding="4,2">
                                    <TextBlock Text="{Binding NetName}" Foreground="#FFD7BDE2" FontSize="10" FontWeight="Bold"
                                               FontFamily="Consolas" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="SelectionHighlight" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.Resources>
                </ItemsControl>

                <!-- Box Selection Overlay (Bound to same coordinate plane) -->
                <Canvas IsHitTestVisible="False">
                    <Rectangle Canvas.Left="{Binding ActiveSchematicViewModel.SelectionBounds.Left}"
                               Canvas.Top="{Binding ActiveSchematicViewModel.SelectionBounds.Top}"
                               Width="{Binding ActiveSchematicViewModel.SelectionBounds.Width}"
                               Height="{Binding ActiveSchematicViewModel.SelectionBounds.Height}"
                               Stroke="#FF007ACC" StrokeThickness="1" Fill="#33007ACC"
                               Visibility="{Binding ActiveSchematicViewModel.IsSelectionBoundsVisible, Converter={StaticResource BoolToVis}}" />
                </Canvas>
                
            </Grid>
        </ScrollViewer>
            
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Background="#FF3F3F46" />
            
            <!-- Output Log / Netlist Panel -->
            <Border Grid.Row="2" Background="#FF2D2D30" BorderBrush="#FF3F3F46" BorderThickness="0,1,0,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,5">
                        <TextBlock Text="Output Log / SPICE Netlist" FontWeight="Bold" Foreground="#FFCCCCCC" VerticalAlignment="Center"/>
                        <Button Content="Generate .cir" Command="{Binding GenerateNetlistCommand}" Margin="15,0,0,0" Padding="10,2" Background="#FF007ACC" Foreground="White" BorderThickness="0" />
                        
                        <Button Content="Run Simulation ▶" Command="{Binding SimulateCommand}" Margin="15,0,0,0" Padding="10,2" Background="#FF2E8B57" Foreground="White" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Stop Simulation ■" Command="{Binding StopSimulationCommand}" Margin="15,0,0,0" Padding="10,2" Background="#FFCC3333" Foreground="White" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <ToggleButton Content="Live Tuning: OFF" IsChecked="{Binding IsLiveTuningEnabled}" Margin="20,0,0,0" Padding="10,2" Background="#FF3F3F46" Foreground="White" BorderThickness="0">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Content" Value="Live Tuning (Polling) ON" />
                                            <Setter Property="Background" Value="#FF9B59B6" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <!-- ═══ Simulation Analysis Type Selector ═══ -->
                        <Separator Margin="12,0" Background="#FF3F3F46"/>
                        <TextBlock Text="Analysis:" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                        <ComboBox SelectedValue="{Binding SimulationType}" SelectedValuePath="Content" Width="110" VerticalAlignment="Center"
                                  Background="#FF3F3F46" Foreground="White" BorderBrush="#FF5F5F66">
                            <ComboBoxItem Content="Transient"/>
                            <ComboBoxItem Content="AC Sweep"/>
                            <ComboBoxItem Content="DC Sweep"/>
                            <ComboBoxItem Content="Noise Analysis"/>
                            <ComboBoxItem Content="Pole-Zero"/>
                            <ComboBoxItem Content="Sensitivity"/>
                        </ComboBox>

                        <!-- Transient params (shown only for Transient) -->
                        <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SimulationType}" Value="AC Sweep">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SimulationType}" Value="DC Sweep">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SimulationType}" Value="Noise Analysis">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SimulationType}" Value="Pole-Zero">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SimulationType}" Value="Sensitivity">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Step:" Foreground="#FF888888" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                            <TextBox Text="{Binding TransientStepTime, UpdateSourceTrigger=PropertyChanged}" Width="55"
                                     Background="#FF333337" Foreground="White" BorderBrush="#FF5F5F66" Padding="3,1" FontSize="11" VerticalContentAlignment="Center"/>
                            <TextBlock Text="Stop:" Foreground="#FF888888" VerticalAlignment="Center" FontSize="11" Margin="8,0,4,0"/>
                            <TextBox Text="{Binding TransientStopTime, UpdateSourceTrigger=PropertyChanged}" Width="55"
                                     Background="#FF333337" Foreground="White" BorderBrush="#FF5F5F66" Padding="3,1" FontSize="11" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- AC params (shown only for AC Sweep) -->
                        <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SimulationType}" Value="AC Sweep">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SimulationType}" Value="Noise Analysis">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="From:" Foreground="#FF888888" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                            <TextBox Text="{Binding AcStartFreq, UpdateSourceTrigger=PropertyChanged}" Width="55"
                                     Background="#FF333337" Foreground="White" BorderBrush="#FF5F5F66" Padding="3,1" FontSize="11" VerticalContentAlignment="Center"/>
                            <TextBlock Text="To:" Foreground="#FF888888" VerticalAlignment="Center" FontSize="11" Margin="8,0,4,0"/>
                            <TextBox Text="{Binding AcStopFreq, UpdateSourceTrigger=PropertyChanged}" Width="60"
                                     Background="#FF333337" Foreground="White" BorderBrush="#FF5F5F66" Padding="3,1" FontSize="11" VerticalContentAlignment="Center"/>
                            <TextBlock Text="Dec:" Foreground="#FF888888" VerticalAlignment="Center" FontSize="11" Margin="8,0,4,0"/>
                            <TextBox Text="{Binding AcPointsPerDecade, UpdateSourceTrigger=PropertyChanged}" Width="40"
                                     Background="#FF333337" Foreground="White" BorderBrush="#FF5F5F66" Padding="3,1" FontSize="11" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- DC Sweep params (shown only for DC Sweep) -->
                        <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SimulationType}" Value="DC Sweep">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Src:" Foreground="#FF888888" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                            <TextBox Text="{Binding DcSweepComponent, UpdateSourceTrigger=PropertyChanged}" Width="35"
                                     Background="#FF333337" Foreground="White" BorderBrush="#FF5F5F66" Padding="3,1" FontSize="11" VerticalContentAlignment="Center"/>
                            <TextBlock Text="Start:" Foreground="#FF888888" VerticalAlignment="Center" FontSize="11" Margin="8,0,4,0"/>
                            <TextBox Text="{Binding DcSweepStart, UpdateSourceTrigger=PropertyChanged}" Width="40"
                                     Background="#FF333337" Foreground="White" BorderBrush="#FF5F5F66" Padding="3,1" FontSize="11" VerticalContentAlignment="Center"/>
                            <TextBlock Text="Stop:" Foreground="#FF888888" VerticalAlignment="Center" FontSize="11" Margin="8,0,4,0"/>
                            <TextBox Text="{Binding DcSweepStop, UpdateSourceTrigger=PropertyChanged}" Width="40"
                                     Background="#FF333337" Foreground="White" BorderBrush="#FF5F5F66" Padding="3,1" FontSize="11" VerticalContentAlignment="Center"/>
                            <TextBlock Text="Step:" Foreground="#FF888888" VerticalAlignment="Center" FontSize="11" Margin="8,0,4,0"/>
                            <TextBox Text="{Binding DcSweepStep, UpdateSourceTrigger=PropertyChanged}" Width="40"
                                     Background="#FF333337" Foreground="White" BorderBrush="#FF5F5F66" Padding="3,1" FontSize="11" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                        <!-- ══ SPICE Netlist ══ -->
                        <TabItem Header="SPICE Netlist" Foreground="#FF007ACC" Background="#FF2D2D30">
                            <TextBox Text="{Binding NetlistOutput, Mode=OneWay}" IsReadOnly="True" Background="#FF1E1E1E" Foreground="#FF4EC9B0" FontFamily="Consolas" BorderThickness="1" BorderBrush="#FF3F3F46" ScrollViewer.VerticalScrollBarVisibility="Auto" Padding="5"/>
                        </TabItem>

                        <!-- ══ Multimeter Instrument ══ -->
                        <TabItem Header="📟 Multimeter" Foreground="#FF2ECC71" Background="#FF2D2D30">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="DIGITAL MULTIMETER DASHBOARD" FontWeight="Bold" Foreground="#FF2ECC71" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text=" — capturing DC, Average, and RMS values from canvas probes" Foreground="#FF888888" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <!-- Empty state when no probes exist -->
                                        <TextBlock Text="No active probes on schematic. Use the '⚡ Probe' or '〜 I-Probe' tools to place probes on wires or components, then run a simulation."
                                                   Foreground="#FF888888" FontSize="12" FontStyle="Italic" TextWrapping="Wrap" Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MultimeterReadings.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Multi-column wrap panel of DMM displays -->
                                        <ItemsControl ItemsSource="{Binding MultimeterReadings}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF1E1E24" BorderBrush="#FF3F3F46" BorderThickness="1.5" CornerRadius="5" Width="220" Margin="0,0,10,10" Padding="8">
                                                        <StackPanel>
                                                            <!-- Probe Header -->
                                                            <Grid Margin="0,0,0,5">
                                                                <TextBlock Text="{Binding Target}" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                                                <Border HorizontalAlignment="Right" Padding="4,2" CornerRadius="3" Background="#FF333337">
                                                                    <TextBlock Text="{Binding Type}" FontSize="9" FontWeight="Bold">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="#FF2ECC71"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Type}" Value="Current">
                                                                                        <Setter Property="Foreground" Value="#FFE67E22"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Border>
                                                            </Grid>
                                                            
                                                            <!-- Digital Display -->
                                                            <Border Background="#FF0C0C0D" BorderBrush="#FF2A2A2E" BorderThickness="1" CornerRadius="3" Padding="8,4" Height="48" Margin="0,0,0,5">
                                                                <TextBlock Text="{Binding ValueText}" FontFamily="Consolas" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#FF00FFCC"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Type}" Value="Current">
                                                                                    <Setter Property="Foreground" Value="#FFFF9800"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>

                                                            <!-- Details Display -->
                                                            <TextBlock Text="{Binding RmsText}" Foreground="#FFAAAAAA" FontSize="9" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>

                        <!-- ══ Spectrum Analyzer ══ -->
                        <TabItem Header="📊 Spectrum Analyzer" Foreground="#FFFF8C00" Background="#FF2D2D30">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Top Toolbar -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8" Grid.Row="0">
                                    <TextBlock Text="Node:" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <ComboBox ItemsSource="{Binding AvailableSpectraNodes}" SelectedItem="{Binding SelectedSpectraNode}" Width="100" VerticalAlignment="Center" Background="#FF333337" Foreground="White" BorderBrush="#FF5F5F66"/>

                                    <TextBlock Text="Window:" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                    <ComboBox SelectedValue="{Binding SelectedFftWindow}" SelectedValuePath="Content" Width="100" VerticalAlignment="Center" Background="#FF333337" Foreground="White" BorderBrush="#FF5F5F66">
                                        <ComboBoxItem Content="Rectangular"/>
                                        <ComboBoxItem Content="Hanning"/>
                                        <ComboBoxItem Content="Hamming"/>
                                        <ComboBoxItem Content="Blackman"/>
                                    </ComboBox>

                                    <Button Content="Analyze Spectrum ▶" Command="{Binding RunSpectraAnalysisCommand}" Margin="12,0,0,0" Padding="12,3" Background="#FFFF8C00" Foreground="Black" FontWeight="Bold" BorderThickness="0"/>
                                    <Button Content="Calculate THD %" Command="{Binding CalculateThdCommand}" Margin="8,0,0,0" Padding="12,3" Background="#FF2EA3F2" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                                    
                                    <TextBlock Text="{Binding SpectraStatus}" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="11" FontStyle="Italic"/>
                                </StackPanel>

                                <!-- Plot Area -->
                                <Border Grid.Row="1" Background="#FF18181A" BorderBrush="#FF3F3F46" BorderThickness="1" CornerRadius="4">
                                    <oxy:PlotView Model="{Binding SpectraPlotModel}"/>
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- ══ Bill of Materials & Live Pricing ══ -->
                        <TabItem Header="📋 BOM &amp; Supply Chain" Foreground="#FF2ECC71" Background="#FF2D2D30">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Top Toolbar -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Filter -->
                                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="🔍 Filter:" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Text="{Binding BomSearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                                 Width="180" Height="24" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                                 Background="#FF1E1E24" Foreground="White" BorderBrush="#FF5F5F66" BorderThickness="1"/>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Orientation="Horizontal" Grid.Column="3" VerticalAlignment="Center">
                                        <Button Content="🔄 Refresh BOM" Command="{Binding UpdateBomCommand}" Margin="0,0,8,0" Padding="12,4" Background="#FF2D2D30" Foreground="White" BorderBrush="#FF5F5F66" BorderThickness="1"/>
                                        <Button Content="📊 Export CSV" Command="{Binding PcbVM.ExportBomCommand}" CommandParameter="{Binding ActiveSchematicViewModel.CoreSchematic}" Margin="0,0,8,0" Padding="12,4" Background="#FF2D2D30" Foreground="White" BorderBrush="#FF5F5F66" BorderThickness="1"/>
                                        <Button Content="📄 Export PDF" Command="{Binding PcbVM.ExportBomPdfCommand}" CommandParameter="{Binding ActiveSchematicViewModel.CoreSchematic}" Padding="12,4" Background="#FF2ECC71" Foreground="Black" FontWeight="Bold" BorderThickness="0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- ListView Grid -->
                                <Border Grid.Row="1" Background="#FF1E1E24" BorderBrush="#FF3F3F46" BorderThickness="1" CornerRadius="4">
                                    <ListView ItemsSource="{Binding BomItems}" Background="Transparent" BorderThickness="0" Foreground="White" AlternationCount="2">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="BorderBrush" Value="#FF2D2D30"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Style.Triggers>
                                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                        <Setter Property="Background" Value="#FF25252A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF353540"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.View>
                                            <GridView>
                                                <!-- Columns -->
                                                <GridViewColumn Header="Line" DisplayMemberBinding="{Binding LineNumber}" Width="40"/>
                                                <GridViewColumn Header="Qty" DisplayMemberBinding="{Binding Quantity}" Width="40"/>
                                                <GridViewColumn Header="Designators" DisplayMemberBinding="{Binding DesignatorString}" Width="100"/>
                                                <GridViewColumn Header="Component" DisplayMemberBinding="{Binding ComponentType}" Width="100"/>
                                                <GridViewColumn Header="Value" DisplayMemberBinding="{Binding Value}" Width="80"/>
                                                <GridViewColumn Header="Part Number" DisplayMemberBinding="{Binding PartNumber}" Width="150"/>
                                                <GridViewColumn Header="Footprint" DisplayMemberBinding="{Binding Footprint}" Width="150"/>
                                                <GridViewColumn Header="Unit Price" Width="80">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding UnitPrice, StringFormat=${0:F3}}" Foreground="#FF2ECC71"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Total Price" Width="80">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding TotalPrice, StringFormat=${0:F2}}" Foreground="#FF2ECC71" FontWeight="Bold"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Stock" DisplayMemberBinding="{Binding Stock}" Width="80"/>
                                                <GridViewColumn Header="Supplier" DisplayMemberBinding="{Binding Distributor}" Width="80"/>
                                                <GridViewColumn Header="Buy Link" Width="70">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Content="🛒 Search" 
                                                                    Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding DistributorUrl}"
                                                                    Padding="6,2" FontSize="9" Background="#FF3C3F41" Foreground="#FF5B6EFF" BorderThickness="0" Cursor="Hand"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Border>

                                <!-- Bottom Cost Bar -->
                                <Border Grid.Row="2" Background="#FF12121E" BorderBrush="#FF2A2A42" BorderThickness="1,0,1,1" CornerRadius="0,0,4,4" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Estimated BOM pricing based on Mouser &amp; DigiKey catalog API queries." Foreground="#FF888888" VerticalAlignment="Center" FontSize="11" FontStyle="Italic"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Estimated Total Project Cost: " Foreground="White" FontWeight="Bold" FontSize="12"/>
                                            <TextBlock Text="{Binding BomTotalCost, StringFormat=${0:F2}}" Foreground="#FF2ECC71" FontWeight="Bold" FontSize="14" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- ══ Function Generator (Virtual Instrument) ══ -->
                        <TabItem Header="📻 Function Generator" Foreground="#FFFF5E99" Background="#FF2D2D30">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="📻 FUNCTION GENERATOR" FontWeight="Bold" Foreground="#FFFF5E99" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text=" — Injects configured waveforms into voltage sources on the schematic" Foreground="#FF888888" FontSize="11" VerticalAlignment="Center" Margin="5,0"/>
                                </StackPanel>

                                <!-- Controls -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Waveform selector -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Waveform" Foreground="#FFAAAAAA" FontSize="10" Margin="0,0,0,3"/>
                                        <ComboBox ItemsSource="{Binding FgenWaveforms}" SelectedItem="{Binding FgenWaveform}"
                                                  Width="90" Background="#FF1E1E24" Foreground="White" BorderBrush="#FF5F5F66"/>
                                    </StackPanel>

                                    <!-- Amplitude -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Amplitude (V)" Foreground="#FFAAAAAA" FontSize="10" Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding FgenAmplitude, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F3}'}"
                                                 Width="80" Background="#FF1E1E24" Foreground="#FF00FFCC" BorderBrush="#FF5F5F66" Padding="4,3" FontFamily="Consolas"/>
                                    </StackPanel>

                                    <!-- Frequency -->
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Frequency (Hz)" Foreground="#FFAAAAAA" FontSize="10" Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding FgenFrequency, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F1}'}"
                                                 Width="90" Background="#FF1E1E24" Foreground="#FF00FFCC" BorderBrush="#FF5F5F66" Padding="4,3" FontFamily="Consolas"/>
                                    </StackPanel>

                                    <!-- DC Offset -->
                                    <StackPanel Grid.Column="6">
                                        <TextBlock Text="DC Offset (V)" Foreground="#FFAAAAAA" FontSize="10" Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding FgenDcOffset, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F3}'}"
                                                 Width="80" Background="#FF1E1E24" Foreground="#FF00FFCC" BorderBrush="#FF5F5F66" Padding="4,3" FontFamily="Consolas"/>
                                    </StackPanel>

                                    <!-- Duty Cycle (for square) -->
                                    <StackPanel Grid.Column="8">
                                        <TextBlock Text="Duty Cycle (%)" Foreground="#FFAAAAAA" FontSize="10" Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding FgenDutyCycle, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F1}'}"
                                                 Width="75" Background="#FF1E1E24" Foreground="#FF00FFCC" BorderBrush="#FF5F5F66" Padding="4,3" FontFamily="Consolas"/>
                                    </StackPanel>

                                    <!-- Target Source -->
                                    <StackPanel Grid.Column="10">
                                        <TextBlock Text="Target Source" Foreground="#FFAAAAAA" FontSize="10" Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding FgenTargetSource, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="60" Background="#FF1E1E24" Foreground="White" BorderBrush="#FF5F5F66" Padding="4,3"/>
                                    </StackPanel>

                                    <!-- Apply button -->
                                    <Button Grid.Column="12" Content="⚡ Apply" Command="{Binding ApplyFunctionGeneratorCommand}"
                                            Padding="16,6" Background="#FFFF5E99" Foreground="Black" FontWeight="Bold" BorderThickness="0"
                                            VerticalAlignment="Bottom"/>
                                </Grid>

                                <!-- Status -->
                                <TextBlock Grid.Row="2" Text="{Binding FgenStatus}" Foreground="#FFAAAAAA"
                                           FontSize="11" FontStyle="Italic" VerticalAlignment="Top" Margin="0,12,0,0" TextWrapping="Wrap"/>
                            </Grid>
                        </TabItem>

                        <!-- ══ Bode Plot ══ -->
                        <TabItem Header="📈 Bode Plot" Foreground="#FF00D2FF" Background="#FF2D2D30">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Toolbar -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Input:" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding BodeInputNode, UpdateSourceTrigger=PropertyChanged}"
                                             Width="80" VerticalAlignment="Center"
                                             Background="#FF1E1E24" Foreground="White" BorderBrush="#FF5F5F66" Padding="3,2"/>

                                    <TextBlock Text="Output:" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="12,0,4,0"/>
                                    <TextBox Text="{Binding BodeOutputNode, UpdateSourceTrigger=PropertyChanged}"
                                             Width="90" VerticalAlignment="Center"
                                             Background="#FF1E1E24" Foreground="White" BorderBrush="#FF5F5F66" Padding="3,2"/>

                                    <Button Content="📈 Plot Bode" Command="{Binding PlotBodeCommand}"
                                            Margin="12,0,0,0" Padding="14,4" Background="#FF00D2FF" Foreground="Black" FontWeight="Bold" BorderThickness="0"/>

                                    <TextBlock Text="{Binding BodeStatus}" Foreground="#FFAAAAAA"
                                               VerticalAlignment="Center" Margin="14,0,0,0" FontSize="11" FontStyle="Italic"/>
                                </StackPanel>

                                <!-- Plot area -->
                                <Border Grid.Row="1" Background="#FF18181A" BorderBrush="#FF3F3F46" BorderThickness="1" CornerRadius="4">
                                    <oxy:PlotView Model="{Binding BodePlotModel}"/>
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- ══ Serial Monitor (MCU Co-Simulation) ══ -->
                        <TabItem Header="📟 Serial Monitor" Foreground="#FF00FF66" Background="#FF2D2D30">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="VIRTUAL UART SERIAL MONITOR" FontWeight="Bold" Foreground="#FF00FF66" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text=" — real-time logging from loaded micro-controller firmware" Foreground="#FF888888" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Clear Console" Command="{Binding ClearSerialMonitorCommand}" Padding="12,4" Background="#FF2D2D30" Foreground="White" BorderBrush="#FF5F5F66" BorderThickness="1"/>
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Row="1" Background="#FF0C0C0D" BorderBrush="#FF2A2A2E" BorderThickness="1.5" CornerRadius="4">
                                    <TextBox Text="{Binding SerialMonitorOutput, Mode=OneWay}" 
                                             IsReadOnly="True" 
                                             AcceptsReturn="True" 
                                             FontFamily="Consolas" 
                                             FontSize="13" 
                                             Background="Transparent" 
                                             Foreground="#FF00FF66" 
                                             BorderThickness="0" 
                                             Padding="10" 
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- ══ Python Console ══ -->
                        <TabItem Header="Python Console" Foreground="#FF9B59B6" Background="#FF2D2D30">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="100" />
                                </Grid.RowDefinitions>
                                <TextBox Grid.Row="0" Text="{Binding PythonScriptCode, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" Background="#FF1E1E1E" Foreground="LightGray" BorderThickness="1" BorderBrush="#FF3F3F46" Margin="0,0,0,5" ToolTip="Enter Python script here. 'circuit' is available as a global variable."/>
                                <Button Grid.Row="1" Content="Run Script" Command="{Binding RunPythonScriptCommand}" HorizontalAlignment="Right" Padding="15,5" Margin="0,0,0,5" Background="#FF007ACC" Foreground="White" BorderThickness="0"/>
                                <TextBox Grid.Row="2" Text="{Binding PythonScriptOutput}" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" Background="#FF2D2D30" Foreground="LawnGreen" BorderThickness="1" BorderBrush="#FF3F3F46" Margin="0" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </TabItem>

                        <!-- ══ Phase 6: Physics / FEA ══ -->
                        <TabItem Header="⚗ Physics" Foreground="#FFFF8C00" Background="#FF2D2D30">
                            <TabControl DataContext="{Binding PhysicsVM}" Background="Transparent" BorderThickness="0">

                                <!-- Sub-tab: Thermal Analysis -->
                                <TabItem Header="Thermal Analysis" Foreground="#FFFF8C00">
                                    <ScrollViewer>
                                    <StackPanel Margin="8">
                                        <TextBlock Text="IC JUNCTION TEMPERATURE ANALYSIS" FontWeight="Bold" Foreground="#FFFF8C00" FontSize="13" Margin="0,0,0,8"/>
                                        <TextBlock Text="Reference: JEDEC JESD51 | RC Thermal Ladder Network" Foreground="#FF888888" FontSize="10" Margin="0,0,0,12"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Power Dissipation (W):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding Power_W, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>

                                                <TextBlock Text="T_Ambient (°C):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding TAmbient_C, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>

                                                <TextBlock Text="R_JC — Junction-to-Case (°C/W):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding RJc_CW, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>

                                                <TextBlock Text="R_CS — Case-to-Sink (°C/W):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding RCs_CW, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>

                                                <TextBlock Text="R_SA — Sink-to-Ambient (°C/W):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding RSa_CW, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>

                                                <TextBlock Text="Max Junction Temp (°C):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding MaxJunction_C, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,10"/>

                                                <Button Content="Analyze Thermal ▶" Command="{Binding RunThermalAnalysisCommand}"
                                                        Background="#FFFF8C00" Foreground="Black" FontWeight="Bold"
                                                        BorderThickness="0" Padding="10,6"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Results:" Foreground="#FFAAAAAA" Margin="0,0,0,4" FontWeight="Bold"/>
                                                <Border Background="#FF1E1E1E" BorderBrush="#FF3F3F46" BorderThickness="1" Padding="8" CornerRadius="4">
                                                    <TextBox Text="{Binding ThermalResult}" IsReadOnly="True" Background="Transparent"
                                                             Foreground="#FF4EC9B0" FontFamily="Consolas" FontSize="11"
                                                             BorderThickness="0" TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <!-- Sub-tab: RF / TL Calculator -->
                                <TabItem Header="RF / Transmission Lines" Foreground="#FFFF8C00">
                                    <ScrollViewer>
                                    <StackPanel Margin="8">
                                        <TextBlock Text="RF TRANSMISSION LINE CALCULATOR" FontWeight="Bold" Foreground="#FFFF8C00" FontSize="13" Margin="0,0,0,8"/>
                                        <TextBlock Text="IPC-2141A | Pozar Microwave Engineering 4th Ed | Wadell 1991" Foreground="#FF888888" FontSize="10" Margin="0,0,0,12"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Topology:" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                                <ComboBox SelectedValue="{Binding TlTopology}" SelectedValuePath="Content"
                                                          Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Margin="0,0,0,6">
                                                    <ComboBoxItem Content="Microstrip"/>
                                                    <ComboBoxItem Content="Stripline"/>
                                                    <ComboBoxItem Content="Coaxial"/>
                                                </ComboBox>

                                                <TextBlock Text="Width (mm)  [or Inner Dia for Coax]:" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding TlWidth_mm, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>

                                                <TextBlock Text="Height/B/OuterDia (mm):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding TlHeight_mm, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>

                                                <TextBlock Text="Substrate εr:" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding TlEr, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>

                                                <TextBlock Text="Frequency (GHz):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding TlFreq_GHz, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>

                                                <TextBlock Text="Target Z0 for Synthesis (Ω):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding TlTargetZ0, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,10"/>

                                                <Button Content="Calculate ▶" Command="{Binding CalculateTxLineCommand}"
                                                        Background="#FFFF8C00" Foreground="Black" FontWeight="Bold"
                                                        BorderThickness="0" Padding="10,6"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Results:" Foreground="#FFAAAAAA" Margin="0,0,0,4" FontWeight="Bold"/>
                                                <Border Background="#FF1E1E1E" BorderBrush="#FF3F3F46" BorderThickness="1" Padding="8" CornerRadius="4">
                                                    <TextBox Text="{Binding TlResult}" IsReadOnly="True" Background="Transparent"
                                                             Foreground="#FF4EC9B0" FontFamily="Consolas" FontSize="11"
                                                             BorderThickness="0" TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <!-- Sub-tab: Deep Research Database -->
                                <TabItem Header="Deep Research Database" Foreground="#FFFF8C00">
                                    <ScrollViewer>
                                    <Grid Margin="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="SECTOR 1: WBG SEMICONDUCTORS" FontWeight="Bold" Foreground="#FFFF8C00" FontSize="11" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding WideBandgapSemiconductors}" 
                                                      SelectedItem="{Binding SelectedWbgMaterial}"
                                                      DisplayMemberPath="Material"
                                                      Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Margin="0,0,0,12"/>

                                            <TextBlock Text="SECTOR 2: BSIM-CMG v107 GEOMETRIES" FontWeight="Bold" Foreground="#FFFF8C00" FontSize="11" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding BsimNodeStatistics}" 
                                                      SelectedItem="{Binding SelectedBsimNode}"
                                                      Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Margin="0,0,0,12">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding NodeNm, StringFormat='{}{0} nm Node'}" Foreground="White"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <TextBlock Text="SECTOR 3: 3D-IC THERMAL STCO PROFILE" FontWeight="Bold" Foreground="#FFFF8C00" FontSize="11" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding ChipletThermalProfiles}" 
                                                      SelectedItem="{Binding SelectedChipletProfile}"
                                                      Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Margin="0,0,0,6">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StackLayers, StringFormat='{}{0}-Layer Chiplet Stack'}" Foreground="White"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <Button Content="Apply Stack params to Thermal Analysis" 
                                                    Command="{Binding ApplyChipletThermalParametersCommand}"
                                                    Background="#FFFF8C00" Foreground="Black" FontWeight="Bold"
                                                    BorderThickness="0" Padding="8,4" Margin="0,0,0,12"/>

                                            <TextBlock Text="SECTOR 4: OPEN-SOURCE PDK SUMMARIES" FontWeight="Bold" Foreground="#FFFF8C00" FontSize="11" Margin="0,0,0,4"/>
                                            <ItemsControl ItemsSource="{Binding OpenSourcePdkDistributions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#FF1E1E1E" BorderBrush="#FF3F3F46" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,4">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Key}" FontWeight="Bold" Foreground="#FF4EC9B0" FontSize="10"/>
                                                                <Grid Margin="0,2,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0">
                                                                        <TextBlock Text="{Binding Value.Vth0Mean, StringFormat='Vth0: {0:F3} V'}" Foreground="#FFAAAAAA" FontSize="9"/>
                                                                        <TextBlock Text="{Binding Value.MobilityMean, StringFormat='Mobility: {0:F0} cm²/Vs'}" Foreground="#FFAAAAAA" FontSize="9"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="{Binding Value.ToxNmMean, StringFormat='Tox: {0:F3} nm'}" Foreground="#FFAAAAAA" FontSize="9"/>
                                                                        <TextBlock Text="{Binding Value.LMinNm, StringFormat='Min L: {0} nm'}" Foreground="#FFAAAAAA" FontSize="9"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Material Properties Output:" Foreground="#FFAAAAAA" Margin="0,0,0,4" FontWeight="Bold"/>
                                            <Border Background="#FF1E1E1E" BorderBrush="#FF3F3F46" BorderThickness="1" Padding="8" CornerRadius="4" Margin="0,0,0,10">
                                                <TextBox Text="{Binding WbgMaterialDetails}" IsReadOnly="True" Background="Transparent"
                                                         Foreground="#FFE8E8A0" FontFamily="Consolas" FontSize="11"
                                                         BorderThickness="0" TextWrapping="Wrap" MinLines="8"/>
                                            </Border>

                                            <TextBlock Text="Technology Node Details:" Foreground="#FFAAAAAA" Margin="0,0,0,4" FontWeight="Bold"/>
                                            <Border Background="#FF1E1E1E" BorderBrush="#FF3F3F46" BorderThickness="1" Padding="8" CornerRadius="4" Margin="0,0,0,10">
                                                <TextBox Text="{Binding BsimNodeDetails}" IsReadOnly="True" Background="Transparent"
                                                         Foreground="#FF4EC9B0" FontFamily="Consolas" FontSize="11"
                                                         BorderThickness="0" TextWrapping="Wrap" MinLines="8"/>
                                            </Border>

                                            <TextBlock Text="Chiplet Thermal Details:" Foreground="#FFAAAAAA" Margin="0,0,0,4" FontWeight="Bold"/>
                                            <Border Background="#FF1E1E1E" BorderBrush="#FF3F3F46" BorderThickness="1" Padding="8" CornerRadius="4">
                                                <TextBox Text="{Binding ChipletProfileDetails}" IsReadOnly="True" Background="Transparent"
                                                         Foreground="#FF9CDCFE" FontFamily="Consolas" FontSize="11"
                                                         BorderThickness="0" TextWrapping="Wrap" MinLines="8"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>
                        </TabItem>

                        <!-- ══ Phase 7: PCB Layout ══ -->
                        <TabItem Header="🖥 PCB Layout" Foreground="#FF4EC9B0" Background="#FF2D2D30">
                            <Grid DataContext="{Binding PcbVM}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>

                                <!-- PCB Controls Panel -->
                                <ScrollViewer Grid.Column="0" Background="#FF252526">
                                    <StackPanel Margin="8">
                                        <TextBlock Text="PCB LAYOUT" FontWeight="Bold" Foreground="#FF4EC9B0" FontSize="13" Margin="0,0,0,8"/>

                                        <TextBlock Text="Board Width (mm):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding BoardWidth, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>
                                        <TextBlock Text="Board Height (mm):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding BoardHeight, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>

                                        <TextBlock Text="Active Layer:" Foreground="#FFAAAAAA" Margin="0,8,0,2"/>
                                        <ComboBox ItemsSource="{Binding AvailableLayers}"
                                                  SelectedValue="{Binding ActiveLayer}"
                                                  Background="#FF333337" Foreground="#FF4EC9B0"
                                                  BorderBrush="#FF3F3F46" Margin="0,0,0,10"/>

                                        <Button Content="Import from Schematic"
                                                Command="{Binding ImportFromSchematicCommand}"
                                                CommandParameter="{Binding DataContext.ActiveSchematicViewModel.CoreSchematic, RelativeSource={RelativeSource AncestorType=Grid}}"
                                                Background="#FF4EC9B0" Foreground="Black" FontWeight="Bold"
                                                BorderThickness="0" Padding="8,6" Margin="0,0,0,4"/>

                                        <Button Content="Auto-Route Board (Built-in)"
                                                Command="{Binding AutoRouteBoardCommand}"
                                                Background="#FFFF8C00" Foreground="Black" FontWeight="Bold"
                                                BorderThickness="0" Padding="8,6" Margin="0,0,0,4"
                                                ToolTip="Automatically routes ratsnest connections using dual-layer orthogonal L-bend paths"/>

                                        <!-- FreeRouting Professional Autorouter Section -->
                                        <Separator Background="#FF3F3F46" Margin="0,4,0,8"/>
                                        <TextBlock Text="PROFESSIONAL AUTOROUTER" FontWeight="Bold" Foreground="#FF9B59B6" Margin="0,0,0,4"/>
                                        <TextBlock Text="FreeRouting (open-source, Java-based)" Foreground="#FF888888" FontSize="9" Margin="0,0,0,4"/>

                                        <!-- FreeRouting availability indicator -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,5,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#FF888888"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFreeRoutingAvailable}" Value="True">
                                                                <Setter Property="Fill" Value="#FF2ECC71"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock VerticalAlignment="Center" FontSize="10">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="FreeRouting: Not Found"/>
                                                        <Setter Property="Foreground" Value="#FF888888"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFreeRoutingAvailable}" Value="True">
                                                                <Setter Property="Text" Value="FreeRouting: Ready"/>
                                                                <Setter Property="Foreground" Value="#FF2ECC71"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Auto-Route via FreeRouting -->
                                        <Button Command="{Binding AutoRouteFreeRoutingCommand}"
                                                Background="#FF9B59B6" Foreground="White" FontWeight="Bold"
                                                BorderThickness="0" Padding="8,6" Margin="0,0,0,4"
                                                ToolTip="Professional autorouting via FreeRouting.&#10;Requires Java 11+ on PATH and FreeRouting JAR in Preferences.">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Content" Value="⚡ Auto-Route (FreeRouting)"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAutoRouting}" Value="True">
                                                            <Setter Property="Content" Value="⏳ Routing in progress…"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Stop Routing (only visible while routing) -->
                                        <Button Content="■ Stop Routing"
                                                Command="{Binding StopAutoRouteCommand}"
                                                Background="#FFCC3333" Foreground="White" FontWeight="Bold"
                                                BorderThickness="0" Padding="8,4" Margin="0,0,0,4"
                                                Visibility="{Binding IsAutoRouting, Converter={StaticResource BoolToVis}}"/>

                                        <!-- Autoroute status -->
                                        <TextBlock Text="{Binding AutoRouteStatus}" Foreground="#FF9B59B6"
                                                   FontSize="9" Margin="0,0,0,6" TextWrapping="Wrap"/>

                                        <!-- Manual DSN/SES workflow -->
                                        <Button Content="Export Specctra DSN…"
                                                Command="{Binding ExportDsnCommand}"
                                                Background="#FF2C3E50" Foreground="#FF9B59B6"
                                                BorderBrush="#FF9B59B6" BorderThickness="1"
                                                Padding="6,4" Margin="0,0,0,2" FontSize="11"
                                                ToolTip="Export board as Specctra .dsn for manual FreeRouting use"/>

                                        <Button Content="Import FreeRouting SES…"
                                                Command="{Binding ImportSesCommand}"
                                                Background="#FF2C3E50" Foreground="#FF9B59B6"
                                                BorderBrush="#FF9B59B6" BorderThickness="1"
                                                Padding="6,4" Margin="0,0,0,8" FontSize="11"
                                                ToolTip="Import the .ses session file output by FreeRouting"/>

                                         <Button Content="Import KiCad PCB Layout…"
                                                 Command="{Binding ImportKicadCommand}"
                                                 Background="#FF2C3E50" Foreground="#FF3498DB"
                                                 BorderBrush="#FF3498DB" BorderThickness="1"
                                                 Padding="6,4" Margin="0,0,0,8" FontSize="11"
                                                 ToolTip="Import footprints, tracks, vias, and outlines from a .kicad_pcb file"/>

                                        <Separator Background="#FF3F3F46" Margin="0,0,0,8"/>

                                        <Button Content="Run DRC" Command="{Binding RunPcbDrcCommand}"
                                                Background="#FFCC3333" Foreground="White" FontWeight="Bold"
                                                BorderThickness="0" Padding="8,6" Margin="0,0,0,4"/>

                                        <Button Content="Export Gerber (All Layers)"
                                                Command="{Binding ExportGerberCommand}"
                                                Background="#FF2E8B57" Foreground="White" FontWeight="Bold"
                                                BorderThickness="0" Padding="8,6" Margin="0,0,0,4"/>

                                        <Button Content="Export BOM (CSV)"
                                                Command="{Binding ExportBomCommand}"
                                                CommandParameter="{Binding DataContext.ActiveSchematicViewModel.CoreSchematic, RelativeSource={RelativeSource AncestorType=Grid}}"
                                                Background="#FF007ACC" Foreground="White" FontWeight="Bold"
                                                BorderThickness="0" Padding="8,6" Margin="0,0,0,4"/>

                                        <Button Content="Export BOM (PDF)"
                                                Command="{Binding ExportBomPdfCommand}"
                                                CommandParameter="{Binding DataContext.ActiveSchematicViewModel.CoreSchematic, RelativeSource={RelativeSource AncestorType=Grid}}"
                                                Background="#FF8E44AD" Foreground="White" FontWeight="Bold"
                                                BorderThickness="0" Padding="8,6" Margin="0,0,0,4"/>

                                        <Button Content="Export Pick &amp; Place (CSV)"
                                                Command="{Binding ExportPickAndPlaceCommand}"
                                                Background="#FF8E2D" Foreground="White" FontWeight="Bold"
                                                BorderThickness="0" Padding="8,6" Margin="0,0,0,4"/>

                                        <Button Content="⬇ Export 3D MCAD Assembly (STEP)"
                                                Command="{Binding ExportStepMcadCommand}"
                                                Background="#FF7D5A00" Foreground="#FFFFE066" FontWeight="Bold"
                                                BorderThickness="1" BorderBrush="#FFFFE066"
                                                Padding="8,6" Margin="0,0,0,8"
                                                ToolTip="Export the full 3D board assembly as an ISO 10303-21 STEP file. Import into SolidWorks, Fusion 360, or Altium 3D."/>

                                        <Separator Background="#FF3F3F46" Margin="0,0,0,8"/>
                                        <TextBlock Text="DESIGN RULES" FontWeight="Bold" Foreground="#FF4EC9B0" Margin="0,0,0,4"/>
                                        <TextBlock Text="IPC-2221B Standard" Foreground="#FF888888" FontSize="10" Margin="0,0,0,4"/>
                                        <TextBlock Text="Min Trace: 0.15mm" Foreground="#FFAAAAAA" FontSize="10"/>
                                                                      <TextBlock Text="Annular Ring: 0.125mm" Foreground="#FFAAAAAA" FontSize="10"/>
                                        <TextBlock Text="Edge Clearance: 0.5mm" Foreground="#FFAAAAAA" FontSize="10"/>
                                    </StackPanel>
                                </ScrollViewer>

                                <!-- PCB Canvas -->
                                <TabControl Grid.Column="1" Background="#FF1A1A2E" BorderBrush="#FF3F3F46" BorderThickness="1"
                                            SelectionChanged="PcbTabControl_SelectionChanged" x:Name="PcbTabControl">
                                    <!-- 2D View Tab -->
                                    <TabItem Header="2D Editor" Foreground="#FF4EC9B0" Background="#FF252526">
                                        <Grid>
                                            <!-- Ratsnest Layer -->
                                            <ItemsControl ItemsSource="{Binding CanvasRatsnestLines}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas ClipToBounds="True" Background="Transparent"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}"
                                                              Stroke="#FF888888" StrokeThickness="1" StrokeDashArray="3 3"
                                                              Opacity="0.75" ToolTip="{Binding NetName, StringFormat='Net: {0} (Unrouted)'}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Traces Layer -->
                                            <ItemsControl ItemsSource="{Binding CanvasTraces}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas ClipToBounds="True" Background="Transparent"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}"
                                                              Stroke="{Binding LayerColor}" StrokeThickness="{Binding Thickness}"
                                                              StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                                              ToolTip="{Binding NetName, StringFormat='Net: {0}'}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Vias Layer -->
                                            <ItemsControl ItemsSource="{Binding CanvasVias}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas ClipToBounds="True" Background="Transparent"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Canvas>
                                                            <!-- Outer copper annular ring (Gold) -->
                                                            <Ellipse Width="{Binding OuterDia}" Height="{Binding OuterDia}"
                                                                     Fill="#FFD7A15C" Stroke="#FFA07030" StrokeThickness="1"
                                                                     Canvas.Left="{Binding LeftOuter}" Canvas.Top="{Binding TopOuter}"
                                                                     ToolTip="{Binding NetName, StringFormat='Via Net: {0}'}"/>
                                                            <!-- Inner drill hole (Black) -->
                                                            <Ellipse Width="{Binding InnerDia}" Height="{Binding InnerDia}"
                                                                     Fill="#FF1A1A2E"
                                                                     Canvas.Left="{Binding LeftInner}" Canvas.Top="{Binding TopInner}"/>
                                                        </Canvas>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Footprints Layer -->
                                            <ItemsControl ItemsSource="{Binding CanvasFootprints}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas ClipToBounds="True" Background="Transparent"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left" Value="{Binding CanvasX}"/>
                                                        <Setter Property="Canvas.Top"  Value="{Binding CanvasY}"/>
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="{Binding Width}" Height="{Binding Height}"
                                                                Background="#FF1E3A5A" BorderBrush="{Binding LayerColor}"
                                                                BorderThickness="1" CornerRadius="2"
                                                                Cursor="Hand" ToolTip="Double-click to edit; Drag to move"
                                                                MouseDown="PcbFootprint_MouseDown"
                                                                MouseMove="PcbFootprint_MouseMove"
                                                                MouseUp="PcbFootprint_MouseUp">
                                                            <Grid>
                                                                <!-- Center text -->
                                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5">
                                                                    <TextBlock Text="{Binding Designator}" Foreground="#FF4EC9B0" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding Value}" Foreground="#FF888888" FontSize="7" HorizontalAlignment="Center"/>
                                                                </StackPanel>

                                                                <!-- Individual pads -->
                                                                <ItemsControl ItemsSource="{Binding VisualPads}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <Canvas Background="Transparent" IsHitTestVisible="False"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Width="{Binding Width}" Height="{Binding Height}"
                                                                                    Background="{Binding Color}" CornerRadius="1"
                                                                                    Canvas.Left="{Binding Left}" Canvas.Top="{Binding Top}"
                                                                                    ToolTip="{Binding Number, StringFormat='Pad {0}'}">
                                                                                <TextBlock Text="{Binding Number}" Foreground="Black" FontSize="6" 
                                                                                           FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Empty state -->
                                            <TextBlock Text="Import schematic to begin PCB layout" Foreground="#FF555555"
                                                       FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanvasFootprints.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </TabItem>

                                    <!-- 3D View Tab -->
                                    <TabItem Header="3D Board View" Foreground="#FFFF8C00" Background="#FF252526">
                                        <Grid>
                                            <helix:HelixViewport3D x:Name="PcbViewport3D" ZoomExtentsWhenLoaded="True" Background="#FF1E1E24"
                                                                  ShowCoordinateSystem="True" ShowFrameRate="False">
                                                <!-- Default Lights -->
                                                <helix:DefaultLights/>
                                            </helix:HelixViewport3D>
                                            
                                            <Button Content="Reset Camera" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10"
                                                    Padding="8,4" Background="#FF007ACC" Foreground="White" BorderThickness="0"
                                                    Click="ResetCamera_Click"/>
                                        </Grid>
                                    </TabItem>
                                </TabControl>

                                <!-- DRC / BOM Output -->
                                <ScrollViewer Grid.Column="2" Background="#FF252526">
                                    <StackPanel Margin="8">
                                        <TextBlock Text="DRC RESULTS" FontWeight="Bold" Foreground="#FFCC3333" Margin="0,0,0,4"/>
                                        <Border Background="#FF1E1E1E" BorderBrush="#FF3F3F46" BorderThickness="1" Padding="6" Margin="0,0,0,8">
                                            <TextBox Text="{Binding DrcOutput}" IsReadOnly="True" Background="Transparent"
                                                     Foreground="#FF4EC9B0" FontFamily="Consolas" FontSize="10"
                                                     BorderThickness="0" TextWrapping="Wrap"/>
                                        </Border>

                                        <TextBlock Text="BILL OF MATERIALS" FontWeight="Bold" Foreground="#FF007ACC" Margin="0,0,0,4"/>
                                        <Border Background="#FF1E1E1E" BorderBrush="#FF3F3F46" BorderThickness="1" Padding="6">
                                            <TextBox Text="{Binding BomOutput}" IsReadOnly="True" Background="Transparent"
                                                     Foreground="#FFE8E8A0" FontFamily="Consolas" FontSize="10"
                                                     BorderThickness="0" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>

                    </TabControl>

                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#FF3F3F46" />

        <!-- ============================================================ -->
        <!-- RIGHT PANEL: Properties + Simulation Controls                -->
        <!-- ============================================================ -->
        <Border Grid.Column="4" Background="#FF252526" BorderBrush="#FF3F3F46" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">

                <!-- Section: Component Properties -->
                <TextBlock Text="Properties" FontWeight="Bold" FontSize="15" Foreground="#FF007ACC" Margin="0,0,0,8"/>

                <StackPanel DataContext="{Binding ComponentProperties}">
                    <!-- No selection placeholder -->
                    <TextBlock Text="Click an item to inspect" Foreground="#FF666666" FontStyle="Italic"
                               Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                               Margin="0,0,0,10"/>

                    <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ComponentType, StringFormat='Type: {0}'}" Foreground="#FF9B59B6" FontWeight="Bold" Margin="0,0,0,4"/>

                        <!-- Conditional Designator vs Net Name label -->
                        <Grid>
                            <TextBlock Text="Designator:" Foreground="#FFAAAAAA" Margin="0,0,0,2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWire}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Net Name:" Foreground="#FFAAAAAA" Margin="0,0,0,2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWire}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <TextBox Text="{Binding Designator, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,8"/>

                        <!-- Value field shown only for components -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWire}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Value:" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,8"/>
                        </StackPanel>

                        <!-- Net ID or Spice Model -->
                        <Grid>
                            <TextBlock Text="{Binding SpiceModelName, StringFormat='Model: {0}'}" Foreground="#FF4EC9B0" FontSize="11" Margin="0,0,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWire}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding SpiceModelName}" Foreground="#FF4EC9B0" FontSize="11" Margin="0,0,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWire}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <TextBlock Text="{Binding PinSummary, StringFormat='Connected Pins: {0}'}" Foreground="#FF666666" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <!-- Firmware selection for MCUs -->
                        <StackPanel Visibility="{Binding IsMcu, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Firmware Path:" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding FirmwarePath, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" IsReadOnly="True"/>
                                <Button Grid.Column="1" Content="..." Command="{Binding BrowseFirmwareCommand}" Width="25" Margin="5,0,0,0"
                                        Background="#FF3F3F46" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>

                        <!-- Switch toggle -->
                        <StackPanel Visibility="{Binding IsSwitch, Converter={StaticResource BoolToVis}}">
                            <CheckBox Content="Switch Closed" IsChecked="{Binding IsClosed}" Foreground="White" Margin="0,0,0,8"/>
                        </StackPanel>

                        <!-- Potentiometer slider -->
                        <StackPanel Visibility="{Binding IsPotentiometer, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Wiper Position:" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="0" Maximum="100" Value="{Binding WiperPercent}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding WiperPercent, StringFormat={}{0:F0}%}" Foreground="#FF9DCBF5" Margin="10,0,0,0" Width="35" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <Separator Background="#FF3F3F46" Margin="0,8,0,8"/>

                <!-- Section: Simulation Type -->
                <TextBlock Text="Simulation" FontWeight="Bold" FontSize="15" Foreground="#FF007ACC" Margin="0,0,0,8"/>

                <TextBlock Text="Analysis Type:" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                <ComboBox SelectedValue="{Binding SimulationType}" SelectedValuePath="Content"
                          Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Margin="0,0,0,10">
                    <ComboBoxItem Content="Transient"/>
                    <ComboBoxItem Content="AC Sweep"/>
                    <ComboBoxItem Content="DC Sweep"/>
                    <ComboBoxItem Content="Noise Analysis"/>
                    <ComboBoxItem Content="Pole-Zero"/>
                    <ComboBoxItem Content="Sensitivity"/>
                </ComboBox>

                <!-- Transient options -->
                <StackPanel Margin="0,0,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SimulationType}" Value="Transient">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Step Time:" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding TransientStepTime, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>
                    <TextBlock Text="Stop Time:" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding TransientStopTime, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>
                </StackPanel>

                <!-- AC Sweep / Noise options -->
                <StackPanel Margin="0,0,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SimulationType}" Value="AC Sweep">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SimulationType}" Value="Noise Analysis">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Start Freq (Hz):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding AcStartFreq, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>
                    <TextBlock Text="Stop Freq (Hz):" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding AcStopFreq, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>
                    <TextBlock Text="Points/Decade:" Foreground="#FFAAAAAA" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding AcPointsPerDecade, UpdateSourceTrigger=PropertyChanged}" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" Padding="4" Margin="0,0,0,6"/>
                </StackPanel>

                <Button Content="Generate Netlist" Command="{Binding GenerateNetlistWithModeCommand}"
                        Margin="0,8,0,4" Padding="8,5" Background="#FF3F3F46" Foreground="White" BorderThickness="0"/>
                <Button Content="Run Simulation ▶" Command="{Binding SimulateCommand}"
                        Margin="0,0,0,4" Padding="8,5" Background="#FF2E8B57" Foreground="White" BorderThickness="0"/>

                <Separator Background="#FF3F3F46" Margin="0,12,0,8"/>

                <!-- Section: SPICE Model Library -->
                <TextBlock Text="📚 SPICE Models" FontWeight="Bold" FontSize="13" Foreground="#FFFF8C00" Margin="0,0,0,6"/>

                <!-- Status indicator -->
                <Border Background="#FF1E2A1E" BorderBrush="#FF2E8B57" BorderThickness="1" CornerRadius="3" Padding="6" Margin="0,0,0,8">
                    <TextBlock Foreground="#FF4EC9B0" FontSize="10" TextWrapping="Wrap"
                               Text="✔ eda_components.lib loaded&#x0a;Diodes • BJT NPN/PNP • MOSFET • Op-Amps&#x0a;Regulators • LEDs • Crystal&#x0a;&#x0a;All models auto-included in netlists."/>
                </Border>

                <!-- Quick reference -->
                <TextBlock Text="Available Models:" Foreground="#FFAAAAAA" FontSize="11" Margin="0,0,0,4"/>
