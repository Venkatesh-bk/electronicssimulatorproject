<Window x:Class="EdaSimulator.UI.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Starting EDA Simulator" Height="300" Width="500"
        WindowStyle="None" WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" Background="Transparent"
        Loaded="Window_Loaded">
    
    <Border Background="#FF1E1E1E" CornerRadius="10" BorderBrush="#FF007ACC" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="EDA SIMULATOR" Foreground="#FF007ACC" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Professional Edition" Foreground="#FF9B59B6" FontSize="18" HorizontalAlignment="Center" Margin="0,5,0,0" x:Name="EditionText"/>
                <TextBlock Text="Version 2026.1" Foreground="#FFAAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>

            <TextBlock x:Name="LoadingStatus" Grid.Row="1" Text="Initializing simulation engines..." Foreground="White" FontSize="11" Margin="20,0,0,5"/>

            <ProgressBar x:Name="LoadProgress" Grid.Row="2" Height="4" Margin="20,0,20,20" Minimum="0" Maximum="100" Value="0"
                         Foreground="#FF007ACC" Background="#FF333333" BorderThickness="0"/>
        </Grid>
    </Border>
</Window>
