<Window x:Class="EdaSimulator.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EdaSimulator.UI.ViewModels"
        Title="Preferences" Height="680" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#FF13131F" Foreground="White" FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:SettingsViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFDDDDDD"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF252540"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3A3A6C"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FF252540"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3A3A6C"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#FF2563EB"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#FF3A3A5C"/>
            <Setter Property="Foreground" Value="#FF9DCBF5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF1A1A30" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚙️" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="Preferences" FontSize="20" FontWeight="Bold" Foreground="#FF5BB4FF"/>
                    <TextBlock Text="EDA Simulator Platform Settings" FontSize="11" Foreground="#FF888AAA"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,14,20,0">
            <StackPanel>

                <!-- Appearance -->
                <GroupBox Header="🎨  Appearance">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Theme"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" SelectedItem="{Binding SelectedTheme}">
                            <ComboBoxItem>DarkPro</ComboBoxItem>
                            <ComboBoxItem>DarkBlue</ComboBoxItem>
                            <ComboBoxItem>LightPro</ComboBoxItem>
                        </ComboBox>
                        <TextBlock Grid.Row="1" Text="Canvas Grid Size (px)"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="5" Maximum="50" Value="{Binding CanvasGridSize}" Width="200" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CanvasGridSize, StringFormat={}{0:F0}}" Margin="10,0,0,0" Foreground="#FF9DCBF5"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2" Text="Display"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                            <CheckBox Content="Show Grid" IsChecked="{Binding ShowGrid}" Margin="0,0,20,0"/>
                            <CheckBox Content="Snap to Grid" IsChecked="{Binding SnapToGrid}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Canvas Display -->
                <GroupBox Header="🖌️  Schematic Display">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Wire Thickness (px)"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="0.5" Maximum="5" Value="{Binding WireThickness}" Width="200" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding WireThickness, StringFormat={}{0:F1}}" Margin="10,0,0,0" Foreground="#FF9DCBF5"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="Show on Canvas"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                            <CheckBox Content="Component Values" IsChecked="{Binding ShowComponentValues}" Margin="0,0,20,0"/>
                            <CheckBox Content="Designators" IsChecked="{Binding ShowDesignators}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2" Text="Wire Color (Hex)"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding WireColor}" MaxWidth="160" HorizontalAlignment="Left"/>
                    </Grid>
                </GroupBox>

                <!-- Simulation -->
                <GroupBox Header="⚡  Simulation Engine">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="ngspice Executable Path"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NgSpicePath}"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="Browse…" Margin="4,0,0,0"
                                Command="{Binding BrowseNgSpiceCommand}"
                                Background="#FF252540" Foreground="#FF9DCBF5" BorderBrush="#FF3A3A6C" Padding="4,0"/>
                        <TextBlock Grid.Row="1" Text="Timeout (seconds)"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SimulationTimeoutSeconds}" MaxWidth="80" HorizontalAlignment="Left"/>
                        <TextBlock Grid.Row="2" Text="Default Analysis"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" SelectedItem="{Binding DefaultSimType}" MaxWidth="200" HorizontalAlignment="Left">
                            <ComboBoxItem>Transient</ComboBoxItem>
                            <ComboBoxItem>AC Sweep</ComboBoxItem>
                            <ComboBoxItem>DC Sweep</ComboBoxItem>
                        </ComboBox>
                        <TextBlock Grid.Row="3" Text="Pre-simulation DRC"/>
                        <CheckBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Content="Auto-run DRC before every simulation" IsChecked="{Binding AutoRunDrc}"/>
                    </Grid>
                </GroupBox>

                <!-- PCB Autorouter -->
                <GroupBox Header="🔌  PCB Autorouter (FreeRouting)">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="26"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="FreeRouting JAR Path"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FreeRoutingJarPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="Browse…" Margin="4,0,0,0"
                                Command="{Binding BrowseFreeRoutingJarCommand}"
                                Background="#FF252540" Foreground="#FF9DCBF5" BorderBrush="#FF3A3A6C" Padding="4,0"/>
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="3" TextWrapping="Wrap" FontSize="10" Foreground="#FF888AAA" Margin="0,2,0,4"
                                   Text="Download freerouting-x.x.x-executable.jar from&#10;https://github.com/freerouting/freerouting/releases — requires Java 11+ on PATH."/>
                        <!-- Availability indicator -->
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal">
                            <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FFCC3333"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FreeRoutingFound}" Value="True">
                                                <Setter Property="Fill" Value="#FF2ECC71"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock VerticalAlignment="Center" FontSize="10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="JAR not found — FreeRouting unavailable"/>
                                        <Setter Property="Foreground" Value="#FFCC3333"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FreeRoutingFound}" Value="True">
                                                <Setter Property="Text" Value="FreeRouting JAR found ✔"/>
                                                <Setter Property="Foreground" Value="#FF2ECC71"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- File / Project -->
                <GroupBox Header="💾  Project &amp; Files">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Auto-Save"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                            <CheckBox Content="Enable Auto-Save" IsChecked="{Binding AutoSaveEnabled}" Margin="0,0,16,0"/>
                            <TextBlock Text="every" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding AutoSaveIntervalMinutes}" Width="40"/>
                            <TextBlock Text=" minutes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="#FF1A1A30" Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Reset to Defaults" Command="{Binding ResetCommand}"
                        Background="#FF7F1D1D" Foreground="White" BorderThickness="0"
                        Padding="14,7" Margin="0,0,10,0"/>
                <Button Content="Save &amp; Close" Command="{Binding SaveCommand}"
                        Background="#FF16A34A" Foreground="White" BorderThickness="0"
                        Padding="18,7" FontWeight="Bold"
                        Click="SaveAndClose_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
