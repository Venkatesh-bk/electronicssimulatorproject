<Window x:Class="EdaSimulator.UI.Views.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Activation" Height="250" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FF1E1E1E" Foreground="White"
        Loaded="Window_Loaded">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Product Activation" FontSize="20" FontWeight="Bold" Foreground="#FF007ACC" Margin="0,0,0,10"/>
        
        <TextBlock x:Name="CurrentLicenseText" Grid.Row="1" Text="Current Edition: Community" Foreground="#FFAAAAAA" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="2" Text="Enter License Key:" Foreground="White" Margin="0,0,0,5"/>
        <TextBox x:Name="LicenseKeyInput" Grid.Row="3" Background="#FF333337" Foreground="White" BorderBrush="#FF3F3F46" 
                 Padding="5" VerticalAlignment="Top" Height="26" FontFamily="Consolas" FontSize="14"
                 ToolTip="Example: PRO-1234-ABCD-5678"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Activate" Click="Activate_Click" Background="#FF007ACC" Foreground="White" BorderThickness="0" Padding="15,5" Margin="0,0,10,0" FontWeight="Bold"/>
            <Button Content="Cancel" Click="Cancel_Click" Background="#FF3F3F46" Foreground="White" BorderThickness="0" Padding="15,5"/>
        </StackPanel>
    </Grid>
</Window>
