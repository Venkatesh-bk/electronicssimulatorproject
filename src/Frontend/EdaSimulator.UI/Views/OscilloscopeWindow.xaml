<Window x:Class="EdaSimulator.UI.Views.OscilloscopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Simulation Analysis - Oscilloscope" Height="600" Width="900"
        Background="#FF1E1E1E"
        WindowStartupLocation="CenterOwner">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="10" BorderBrush="#FF3F3F46" BorderThickness="1" Background="#FF252526">
            <oxy:PlotView Model="{Binding SimPlotModel}" Background="Transparent" />
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,10,10">
            <Button Content="Clear Traces" Width="100" Margin="0,0,10,0"
                    Background="#FF3F3F46" Foreground="White" BorderThickness="0" Padding="5" />
            <Button Content="Close Analysis" Width="100" 
                    Background="#FF007ACC" Foreground="White" BorderThickness="0" Padding="5" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
