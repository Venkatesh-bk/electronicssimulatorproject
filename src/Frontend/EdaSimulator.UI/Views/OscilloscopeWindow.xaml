<Window x:Class="EdaSimulator.UI.Views.OscilloscopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Simulation Analysis — Waveform Viewer"
        Height="680" Width="1050"
        MinHeight="450" MinWidth="700"
        Background="#FF111118"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="#FF2D2D3F"/>
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3D3D5F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF5B6EFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background" Value="#FF5B6EFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF7B8EFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background" Value="#FF8B2020"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFCC3333"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Plot -->
            <RowDefinition Height="Auto"/> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ TOOLBAR ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#FF1A1A28" BorderBrush="#FF2A2A42" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">

                <!-- Title -->
                <TextBlock Text="⚡ WAVEFORM VIEWER" FontSize="12" FontWeight="Bold"
                           Foreground="#FF5B6EFF" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <!-- Zoom controls -->
                <TextBlock Text="Zoom:" Foreground="#FF666688" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                <Button x:Name="ZoomInBtn"  Content="＋" Style="{StaticResource ToolBtn}" Margin="0,0,2,0" Click="ZoomInBtn_Click"/>
                <Button x:Name="ZoomOutBtn" Content="－" Style="{StaticResource ToolBtn}" Margin="0,0,2,0" Click="ZoomOutBtn_Click"/>
                <Button x:Name="ZoomFitBtn" Content="⊡ Fit" Style="{StaticResource ToolBtn}" Margin="0,0,16,0" Click="ZoomFitBtn_Click"/>

                <!-- Measurements -->
                <Button x:Name="MeasureBtn" Content="📏 Measurements" Style="{StaticResource ToolBtn}" Margin="0,0,2,0" Click="MeasureBtn_Click"/>

                <Separator Width="1" Background="#FF2A2A42" Margin="10,6"/>

                <!-- Math Channel Input -->
                <TextBlock Text="Math:" Foreground="#FF666688" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                <TextBox x:Name="MathExpressionTxt" Width="130" Height="22" 
                         Background="#FF12121E" Foreground="White" BorderBrush="#FF2A2A42" BorderThickness="1"
                         VerticalAlignment="Center" VerticalContentAlignment="Center" Margin="0,0,4,0"
                         FontFamily="Consolas" FontSize="11" Text="V(V_OUT)-V(V_IN)"/>
                <Button x:Name="AddMathBtn" Content="Add ƒ" Style="{StaticResource ToolBtn}" Margin="0,0,10,0" Click="AddMathBtn_Click"/>

                <Separator Width="1" Background="#FF2A2A42" Margin="10,6"/>

                <!-- Export -->
                <Button x:Name="ExportCsvBtn" Content="📊 Export CSV" Style="{StaticResource ToolBtn}" Margin="0,0,2,0" Click="ExportCsvBtn_Click"/>
                <Button x:Name="ExportPngBtn" Content="🖼 Save PNG"   Style="{StaticResource ToolBtn}" Margin="0,0,16,0" Click="ExportPngBtn_Click"/>

                <!-- Clear / Close -->
                <Button x:Name="ClearBtn"  Content="🗑 Clear"  Style="{StaticResource DangerBtn}" Margin="0,0,2,0" Click="ClearBtn_Click"/>
                <Button x:Name="CloseBtn"  Content="✕ Close"   Style="{StaticResource ToolBtn}"   Margin="0,0,0,0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <!-- ═══ MAIN CONTENT (Plot + Trace Panel) ═══════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- Plot -->
            <Border Grid.Column="0" Margin="8,8,4,8" Background="#FF0E0E18"
                    BorderBrush="#FF2A2A42" BorderThickness="1" CornerRadius="4">
                <oxy:PlotView x:Name="PlotView" Model="{Binding SimPlotModel}" Background="Transparent"/>
            </Border>

            <!-- Trace panel -->
            <Border Grid.Column="1" Margin="4,8,8,8" Background="#FF1A1A28"
                    BorderBrush="#FF2A2A42" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Trace panel header -->
                    <Border Grid.Row="0" Background="#FF12121E" Padding="10,8" CornerRadius="4,4,0,0">
                        <TextBlock Text="Traces" FontSize="12" FontWeight="Bold" Foreground="#FF9999CC"/>
                    </Border>

                    <!-- Trace list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="TraceList" ItemsSource="{Binding TraceInfos}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" BorderBrush="#FF2A2A42" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Color bar -->
                                            <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,6,0"
                                                    Background="{Binding ColorHex}" HorizontalAlignment="Left"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}" Foreground="White"
                                                           FontSize="10" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding StatsText}" Foreground="#FF666688"
                                                           FontSize="9" FontFamily="Consolas"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Measurement results panel -->
                    <Border Grid.Row="2" Background="#FF12121E" Padding="8" CornerRadius="0,0,4,4">
                        <StackPanel>
                            <TextBlock Text="Measurements" FontSize="10" FontWeight="Bold"
                                       Foreground="#FF666688" Margin="0,0,0,4"/>
                            <TextBlock x:Name="MeasurementText"
                                       Text="Click 📏 to measure"
                                       Foreground="#FF444466" FontSize="9" FontFamily="Consolas"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ STATUS BAR ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#FF0A0A14" Padding="10,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText"
                           Text="Ready — run a simulation to display waveforms."
                           Foreground="#FF444466" FontSize="10" FontFamily="Consolas"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
